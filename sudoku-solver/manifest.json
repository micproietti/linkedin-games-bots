{
  "manifest_version": 3,
  "name": "LinkedIn Sudoku Solver",
  "version": "1.0",
  "description": "Automatically solves the LinkedIn Mini Sudoku.",
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "sudoku-logo16.png",
    "32": "sudoku-logo32.png",
    "48": "sudoku-logo48.png",
    "128": "sudoku-logo128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
